# 复制为 packages/editor/.env.production，将 YOUR_SERVER_IP 换成 Linux 服务器内网 IP
# 内网标准部署（Nginx 静态 8080/8081 + API 直连 3002）：
VITE_API_BASE=http://YOUR_SERVER_IP:3002
# 勿用 127.0.0.1，除非只有服务器本机浏览器访问
# 可选：API 经 Nginx 8082 反代时改为 http://YOUR_SERVER_IP:8082（见 doc/deploy-linux-nginx.md §1.1.1）


# 与后端 PAGE_POLICY=strict 成对（可选）
VITE_PAGE_POLICY=strict
