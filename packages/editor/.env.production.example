# 复制为 packages/editor/.env.production，构建前将 YOUR_SERVER_IP 换成 Linux 服务器内网 IP
# 无 Nginx 试运行：API 直连 :3002 → VITE_API_BASE=http://YOUR_SERVER_IP:3002
# 上 Nginx 后（方案 A 8082 反代）：改为 http://YOUR_SERVER_IP:8082

VITE_API_BASE=http://YOUR_SERVER_IP:3002

# 与后端 PAGE_POLICY=strict 成对（可选）
VITE_PAGE_POLICY=strict
