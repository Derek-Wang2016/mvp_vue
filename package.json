{
  "name": "mvp-vue",
  "private": true,
  "description": "轻量级 Web 可视化大屏平台 — Vue 3 重构版（工作目录）",
  "scripts": {
    "dev:editor": "pnpm -F @mvp-vue/editor dev",
    "dev:renderer": "pnpm -F @mvp-vue/renderer dev",
    "dev:server": "pnpm -F @mvp-vue/server dev",
    "build:editor": "pnpm -F @mvp-vue/editor build",
    "build:renderer": "pnpm -F @mvp-vue/renderer build",
    "prisma:generate": "pnpm -F @mvp-vue/server exec prisma generate",
    "build:schema": "pnpm -F @mvp-vue/schema build",
    "build:server": "pnpm -F @mvp-vue/schema build && pnpm -F @mvp-vue/server build",
    "prepare:trial-env": "node scripts/prepare-trial-env.mjs",
    "build:trial": "node scripts/prepare-trial-env.mjs && pnpm build && pnpm prisma:generate && pnpm build:server",
    "preview:editor": "pnpm -F @mvp-vue/editor exec vite preview --host 0.0.0.0 --port 8080",
    "preview:renderer": "pnpm -F @mvp-vue/renderer exec vite preview --host 0.0.0.0 --port 8081",
    "build": "pnpm -r --filter @mvp-vue/editor --filter @mvp-vue/renderer run build"
  },
  "engines": {
    "node": ">=20.12.0",
    "pnpm": ">=9.0.0"
  }
}
