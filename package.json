{
  "name": "mvp-vue",
  "private": true,
  "description": "轻量级 Web 可视化大屏平台 — Vue 3 重构版（工作目录）",
  "scripts": {
    "dev:editor": "pnpm -F @mvp-vue/editor dev",
    "dev:renderer": "pnpm -F @mvp-vue/renderer dev",
    "dev:server": "pnpm -F @mvp-vue/server dev",
    "build:editor": "pnpm -F @mvp-vue/editor build",
    "build:renderer": "pnpm -F @mvp-vue/renderer build",
    "build": "pnpm -r --filter './packages/*' --filter '!@mvp-vue/server' run build"
  },
  "engines": {
    "node": ">=20.12.0",
    "pnpm": ">=9.0.0"
  }
}
