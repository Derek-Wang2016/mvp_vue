# 内网部署示例：Nginx 仅托管 Editor/Renderer 静态站，API 由 Node 直连 :3002
# 复制到 /etc/nginx/sites-available/mvp-vue 后修改 root 路径与 server_name
#
#   sudo cp doc/nginx/mvp-intranet.conf.example /etc/nginx/sites-available/mvp-vue
#   sudo ln -sf /etc/nginx/sites-available/mvp-vue /etc/nginx/sites-enabled/
#   sudo nginx -t && sudo systemctl reload nginx

# Editor — 5000
server {
    listen 5000;
    server_name _;

    root /var/www/mvp_vue/editor;
    index index.html;

    location / {
        try_files $uri $uri/ /index.html;
    }
}

# Renderer — 5001
server {
    listen 5001;
    server_name _;

    root /var/www/mvp_vue/renderer;
    index index.html;

    location / {
        try_files $uri $uri/ /index.html;
    }
}

# 不在此反代 API；浏览器请求 http://<服务器IP>:3002（构建时 VITE_API_BASE 须一致）
